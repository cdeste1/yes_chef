  "sub_recipes": [
    {
      "name": "Ember-Roasted Squash",
      "ingredients": [
        {
          "item": "Butternut squash",
          "quantity": "2 medium"
        },
        {
          "item": "Cultured butter",
          "quantity": "3 tbsp"
        },
        {
          "item": "White miso",
          "quantity": "1 tbsp"
        },
        {
          "item": "Maple syrup",
          "quantity": "1 tbsp"
        },
        {
          "item": "Aged sherry vinegar",
          "quantity": "1 tbsp"
        },
        {
          "item": "Maldon salt",
          "quantity": "to taste"
        },
        {
          "item": "Tellicherry pepper",
          "quantity": "to taste"
        }
      ],
      "steps": [
        {
          "number": 1,
          "instruction": "Peel squash and cut into cylinders using ring molds or turning slicer; reserve scraps for purée."
        },
        {
          "number": 2,
          "instruction": "Caramelize cylinders on a plancha over high heat, then roast at 375°F until tender."
        },
        {
          "number": 3,
          "instruction": "Brush with a reduction of miso, maple syrup, and vinegar until lacquered and glossy."
        }
      ]
    },
    {
      "name": "Smoked Squash Silk Purée",
      "ingredients": [
        {
          "item": "Roasted squash flesh (scraps)",
          "quantity": "2 cups"
        },
        {
          "item": "Heavy cream",
          "quantity": "1/2 cup"
        },
        {
          "item": "Brown butter",
          "quantity": "2 tbsp"
        },
        {
          "item": "Roasted shallot",
          "quantity": "1 small"
        },
        {
          "item": "Saffron",
          "quantity": "pinch"
        }
      ],
      "steps": [
        {
          "number": 1,
          "instruction": "Blend all ingredients until completely smooth."
        },
        {
          "number": 2,
          "instruction": "Pass through a chinois sieve."
        },
        {
          "number": 3,
          "instruction": "Cold-smoke under a cloche for 45 seconds using applewood dust."
        }
      ]
    },
    {
      "name": "Burnt Sage Oil",
      "ingredients": [
        {
          "item": "Grapeseed oil",
          "quantity": "1 cup"
        },
        {
          "item": "Sage leaves",
          "quantity": "15"
        }
      ],
      "steps": [
        {
          "number": 1,
          "instruction": "Heat oil to 175°F and fry sage leaves until nearly blackened."
        },
        {
          "number": 2,
          "instruction": "Blend for 2 minutes and strain through cheesecloth."
        }
      ]
    },
    {
      "name": "Compressed Pear Ribbons",
      "ingredients": [
        {
          "item": "Asian pear",
          "quantity": "1"
        },
        {
          "item": "Pear juice",
          "quantity": "1 tbsp"
        },
        {
          "item": "Lemon juice",
          "quantity": "1 tsp"
        }
      ],
      "steps": [
        {
          "number": 1,
          "instruction": "Slice pear into long ribbons and vacuum seal with juices."
        },
        {
          "number": 2,
          "instruction": "Chill for 20 minutes until translucent."
        }
      ]
    },
    {
      "name": "Hazelnut Praline Dust",
      "ingredients": [
        {
          "item": "Toasted hazelnuts",
          "quantity": "1/2 cup"
        },
        {
          "item": "Sugar",
          "quantity": "1/4 cup"
        },
        {
          "item": "Flaky salt",
          "quantity": "pinch"
        }
      ],
      "steps": [
        {
          "number": 1,
          "instruction": "Caramelize sugar in copper pot, add hazelnuts, and cool on a silicone mat."
        },
        {
          "number": 2,
          "instruction": "Pulse in food processor until crumbly."
        }
      ]
    },
    {
      "name": "Black Garlic Reduction",
      "ingredients": [
        {
          "item": "Black garlic cloves",
          "quantity": "4"
        },
        {
          "item": "Veal stock or vegetable demi-glace",
          "quantity": "1/2 cup"
        },
        {
          "item": "Balsamic vinegar",
          "quantity": "1 tsp"
        }
      ],
      "steps": [
        {
          "number": 1,
          "instruction": "Blend ingredients and simmer until thick enough to coat a spoon; strain."
        }
      ]
    }
  ]
}

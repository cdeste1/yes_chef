  "steps": [
    {
      "number": 1,
      "instruction": "Prepare the Foie Gras Espuma and Smoked Truffle Aioli",
      "note": "see sub-recipe"
    },
    {
      "number": 2,
      "instruction": "Prepare the Vacuum-Smoked Brioche Buns",
      "note": "see sub-recipe"
    },
    {
      "number": 3,
      "instruction": "Sous-vide the Wagyu sausages in the Polyscience circulator at exactly 60°C (140°F) for 45 minutes."
    },
    {
      "number": 4,
      "instruction": "Shock sausages in ice water for 2 minutes, pat dry, then sear briefly with the Searzall torch or hot pan for Maillard crust."
    },
    {
      "number": 5,
      "instruction": "Using precision tweezers and plating tools, begin assembly on a pristine white plate."
    },
    {
      "number": 6,
      "instruction": "Spread smoked truffle aioli inside the warm smoked bun, nestle the hot sausage, and pipe a ribbon of foie-gras espuma from the siphon."
    },
    {
      "number": 7,
      "instruction": "Shave 5–6 paper-thin slices of black truffle directly onto the espuma using the Brevetti slicer."
    },
    {
      "number": 8,
      "instruction": "Add tiny quenelles of Ossetra caviar with tweezers, microgreens, and 2–3 flakes of edible gold leaf. Optional: artistic swipe of aged balsamic."
    },
    {
      "number": 9,
      "instruction": "Serve immediately with negative space for dramatic Michelin-style presentation."
    }

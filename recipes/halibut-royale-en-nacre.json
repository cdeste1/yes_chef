{
  "name": "Halibut Royale en Nacre",
  "description": "A refined Michelin-style halibut dish featuring butter-poached fish, champagne beurre blanc, and delicate spring vegetables with luxurious garnishes.",
  "category": "Main",
  "keywords": "halibut, fine dining, seafood, michelin, beurre blanc",
  "yield": "2 plates",
  "source": "Restaurant Guy Savoy",
  "chef": "Guy Savoy",
  "imageUrl": "https://pub-3ae50d56fa834654954be23601470560.r2.dev/assets/Photos/Recipes/Halibut.png",
  "ingredients": [
    {
      "quantity": "2 (6 oz each)",
      "item": "Halibut fillets (center-cut, skinless)",
      "note": ""
    },
    {
      "quantity": "350 g",
      "item": "Unsalted butter",
      "note": "divided for poaching and sauce"
    },
    {
      "quantity": "1",
      "item": "Garlic clove",
      "note": "crushed"
    },
    {
      "quantity": "1",
      "item": "Thyme sprig",
      "note": ""
    },
    {
      "quantity": "1",
      "item": "Shallot",
      "note": "finely minced"
    },
    {
      "quantity": "150 ml",
      "item": "Champagne",
      "note": ""
    },
    {
      "quantity": "1 tbsp",
      "item": "White wine vinegar",
      "note": ""
    },
    {
      "quantity": "1/2 cup",
      "item": "English peas",
      "note": ""
    },
    {
      "quantity": "4-6",
      "item": "Baby leeks or scallions",
      "note": ""
    },
    {
      "quantity": "small handful",
      "item": "Microgreens",
      "note": ""
    },
    {
      "quantity": "to finish",
      "item": "Lemon zest",
      "note": ""
    },
    {
      "quantity": "to taste",
      "item": "Salt and white pepper",
      "note": ""
    },
    {
      "quantity": "Small spoonful",
      "item": "Caviar (optional)",
      "note": ""
    },
    {
      "quantity": "For garnish",
      "item": "Edible flowers (optional)",
      "note": ""
    },
    {
      "quantity": "For garnish",
      "item": "Gold leaf (optional)",
      "note": ""
    }
  ],
  "steps": [
    {
      "instruction": "Season the halibut lightly with salt and white pepper and place into a vacuum bag with butter, garlic, and thyme."
    },
    {
      "instruction": "Seal and cook in a water bath at 122°F (50°C) for 25 minutes."
    },
    {
      "instruction": "Prepare the Champagne Beurre Blanc"
    },
    {
      "instruction": "Blanch peas in salted boiling water, then shock in ice water."
    },
    {
      "instruction": "Lightly sauté baby leeks in butter until tender."
    },
    {
      "instruction": "Remove halibut from bag and gently pat dry."
    },
    {
      "instruction": "Sear halibut briefly in a hot pan with butter to create a light golden crust."
    },
    {
      "instruction": "Plating: Spoon beurre blanc onto the plate as a base."
    },
    {
      "instruction": "Place halibut slightly off-center on the sauce."
    },
    {
      "instruction": "Arrange peas and leeks with height and balance."
    },
    {
      "instruction": "Garnish with microgreens, lemon zest, and optional caviar or gold leaf."
    }
  ],

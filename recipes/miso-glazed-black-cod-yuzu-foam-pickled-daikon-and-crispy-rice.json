{
  "name": "Miso-Glazed Black Cod, Yuzu Foam, Pickled Daikon and Crispy Rice",
  "description": "A refined Asian fusion dish featuring buttery miso-marinated black cod, bright yuzu foam, compressed pickled daikon, and crispy sushi rice.",
  "category": "Main",
  "keywords": "black cod, miso, asian fusion, fine dining, seafood",
  "yield": "2 plates",
  "source": "Nobu",
  "chef": "Nobu Matsuhisa",
  "imageUrl": "https://pub-3ae50d56fa834654954be23601470560.r2.dev/assets/Photos/Recipes/Miso_Cod.png",
  "ingredients": [
    {
      "quantity": "2",
      "item": "Black cod fillets",
      "note": ""
    },
    {
      "quantity": "1/2 cup",
      "item": "White miso",
      "note": ""
    },
    {
      "quantity": "1/4 cup",
      "item": "Mirin",
      "note": ""
    },
    {
      "quantity": "3 tbsp",
      "item": "Sake",
      "note": ""
    },
    {
      "quantity": "2 tbsp",
      "item": "Sugar",
      "note": ""
    },
    {
      "quantity": "1 cup (cooked and chilled)",
      "item": "Sushi rice",
      "note": ""
    },
    {
      "quantity": "for frying",
      "item": "Neutral oil",
      "note": ""
    },
    {
      "quantity": "",
      "item": "Pickled Daikon",
      "note": "see sub-recipe"
    },
    {
      "quantity": "",
      "item": "Yuzu Foam",
      "note": "see sub-recipe"
    },
    {
      "quantity": "small handful",
      "item": "Microgreens",
      "note": ""
    },
    {
      "quantity": "pinch",
      "item": "Black sesame seeds",
      "note": ""
    },
    {
      "quantity": "optional",
      "item": "Shiso leaves",
      "note": ""
    }
  ],
  "steps": [
    {
      "instruction": "Prepare the miso marinade by whisking miso, mirin, sake, and sugar until smooth."
    },
    {
      "instruction": "Coat the black cod and refrigerate for 12–24 hours."
    },
    {
      "instruction": "Prepare Pickled Daikon using the sub-recipe."
    },
    {
      "instruction": "Prepare Yuzu Foam using the sub-recipe."
    },
    {
      "instruction": "Rinse excess marinade from cod, vacuum seal, and cook sous vide at 122°F (50°C) for 25 minutes."
    },
    {
      "instruction": "Press sushi rice into a flat sheet, cut into shapes, and fry at 375°F until golden and crispy."
    },
    {
      "instruction": "Remove cod from bag, pat dry, and brush lightly with miso glaze."
    },
    {
      "instruction": "Use a blowtorch to caramelize the surface until glossy."
    },
    {
      "instruction": "Plating Layer 1: Place crispy rice as the base."
    },
    {
      "instruction": "Plating Layer 2: Place cod on top and add pickled daikon curls."
    },
    {
      "instruction": "Plating Layer 3: Dispense yuzu foam beside the fish and garnish with microgreens and sesame seeds."
    }
  ],

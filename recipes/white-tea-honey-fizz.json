{
  "name": "White Tea & Honey Fizz",
  "source": "adapted from Death & Co.",
  "imageUrl": "https://pub-3ae50d56fa834654954be23601470560.r2.dev/assets/Photos/Recipes/WhiteTea_HoneyFizz.webp",
  "chef": " Javelle Taft",
  "yield": "1",
  "description": "A light, floral aperitif built on white tea, gin, and bubbles.",
  "category": "Cocktail",
  "keywords": "white tea, honey, aperitif, gin, fizz",
  "specialtools": [
    {
      "item": "Drink Shaker Set",
      "link": "https://amzn.to/3XFD0JO"
    }
  ],
  "ingredients": [
    {
      "item": "Gin",
      "quantity": "1 ounce"
    },
    {
      "item": "White Tea Honey Syrup",
      "quantity": "1 ounce",
      "note": "see sub-recipe"
    },
    {
      "item": "Lemon Juice",
      "quantity": "1/2 ounce"
    },
    {
      "item": "Sparkling Water",
      "quantity": "2 ounces"
    },
    {
      "item": "Edible Flower",
      "quantity": "1, garnish"
    }
  ],
  "steps": [
    {
      "number": 1,
      "instruction": "Shake gin, syrup, and lemon juice with ice."
    },
    {
      "number": 2,
      "instruction": "Strain into a chilled glass and top with sparkling water."
    },
    {
      "number": 3,
      "instruction": "Garnish with an edible flower."
    }
  ],
  "sub_recipes": [
    {
      "name": "White Tea Honey Syrup",
      "ingredients": [
        {
          "item": "White Tea",
          "quantity": "1 tablespoon"
        },
        {
          "item": "Hot Water",
          "quantity": "1 cup"
        },
        {
          "item": "Honey",
          "quantity": "1 cup"
        }
      ],
      "steps": [
        {
          "number": 1,
          "instruction": "Steep the white tea in hot water for 4 minutes."
        },
        {
          "number": 2,
          "instruction": "Strain and whisk in honey until dissolved."
        },
        {
          "number": 3,
          "instruction": "Cool and refrigerate."
        }
      ]
    }
  ]
}

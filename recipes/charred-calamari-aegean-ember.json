      "steps": [
        {
          "number": 1,
          "instruction": "Roast squid trimmings until deeply caramelized."
        },
        {
          "number": 2,
          "instruction": "Add shallot and garlic, then deglaze with vermouth."
        },
        {
          "number": 3,

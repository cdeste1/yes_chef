  "steps": [
    {
      "number": 1,
      "instruction": "Cut pasta rounds, fill with cheese mix, and seal to form ravioli."
    },
    {
      "number": 1,
      "instruction": "Spoon filling into the center of one round."
    },
    {
      "number": 1,
      "instruction": "Place a round on top and seal edges, making sure no air is trapped."
    },
    {
      "number": 2,
      "instruction": "Boil ravioli for 2–3 minutes until tender."
    },
    {
      "number": 3,
      "instruction": "Toss gently in truffle essence sauce."
    },
    {
      "number": 4,
      "instruction": "Arrange on plate, spoon over sauce, and garnish with shaved truffle and pepper."

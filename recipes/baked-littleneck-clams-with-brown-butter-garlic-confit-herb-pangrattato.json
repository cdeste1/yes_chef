  "steps": [
    {
      "instruction": "Prepare garlic confit by slowly cooking garlic, olive oil, thyme, and lemon zest at low heat until soft and aromatic."
    },
    {
      "instruction": "Steam clams with white wine until just opened, then remove top shells and strain reserved liquid."
    },
    {
      "instruction": "Make pangrattato by saut�ing shallots and anchovy in clarified butter, then adding breadcrumbs and toasting until golden. Finish with herbs and lemon zest."
    },
    {
      "instruction": "Prepare brown butter by cooking butter until nutty and golden, then blending with garlic confit, lemon juice, white wine, and a touch of clam liquor."
    },
    {
      "instruction": "Preheat oven to 450�F and spread kosher salt on a tray to hold clams steady."
    },
    {
      "instruction": "Place clams on tray, spoon brown butter emulsion over each, and top with pangrattato."
    },
    {
      "instruction": "Bake for 5�7 minutes until golden and bubbling."
    },
    {
      "instruction": "Finish with Maldon salt, Espelette pepper, and fresh herbs before serving."
    }
  ],

  "sub_recipes": [
    {
      "name": "Vegetable Consommé",
      "yield": "",
      "ingredients": [
        {
          "item": "Carrots",
          "quantity": "2",
          "note": "roughly chopped"
        },
        {
          "item": "Leeks",
          "quantity": "1",
          "note": "cleaned and sliced"
        },
        {
          "item": "Celery stalks",
          "quantity": "2",
          "note": "roughly chopped"
        },
        {
          "item": "Onion",
          "quantity": "1",
          "note": "quartered"
        },
        {
          "item": "Tomato paste",
          "quantity": "1 tbsp"
        },
        {
          "item": "Egg whites",
          "quantity": "3",
          "note": "for clarification"
        },
        {
          "item": "Cold water",
          "quantity": "1.5 L"
        },
        {
          "item": "Salt",
          "quantity": "",
          "note": "to taste"
        }
      ],
      "steps": [
        {
          "number": 1,
          "instruction": "Combine vegetables, tomato paste, and cold water in a large pot. Simmer for 45–60 minutes to extract flavor."
        },
        {
          "number": 2,
          "instruction": "Strain through fine mesh sieve."
        },
        {
          "number": 3,
          "instruction": "Whisk egg whites and add to strained broth. Slowly bring to a simmer to form a raft that clarifies the liquid."
        },
        {
          "number": 4,
          "instruction": "Carefully ladle the clear consommé from under the raft."
        },
        {
          "number": 5,
          "instruction": "Season lightly with salt before serving."
        }
      ]
    },
    {
      "name": "Edible Flower Ravioli",
      "yield": "",
      "ingredients": [
        {
          "item": "00 flour",
          "quantity": "200 g"
        },
        {
          "item": "Eggs",
          "quantity": "2"
        },
        {
          "item": "Ricotta cheese",
          "quantity": "150 g"
        },
        {
          "item": "Parmesan cheese",
          "quantity": "30 g",
          "note": "grated"
        },
        {
          "item": "Edible flowers",
          "quantity": "Handful",
          "note": "nasturtiums, pansies, or violets, finely chopped"
        },
        {
          "item": "Salt",
          "quantity": "Pinch"
        }
      ],
      "steps": [
        {
          "number": 1,
          "instruction": "Make pasta dough by mixing flour and eggs; knead until smooth. Rest for 30 minutes."
        },
        {
          "number": 2,
          "instruction": "Roll dough into thin sheets using pasta roller."
        },
        {
          "number": 3,
          "instruction": "Combine ricotta, Parmesan, and chopped edible flowers for filling."
        },
        {
          "number": 4,
          "instruction": "Spoon small portions of filling onto pasta sheet, cover with another sheet, and seal edges."
        },
        {
          "number": 5,
          "instruction": "Cut into ravioli shapes and cook gently in salted boiling water for 2–3 minutes."
        }
      ]
    }
  ]
}

  "sub_recipes": [
    {
      "name": "Beef Tenderloin",
      "yield": "",
      "ingredients": [
        {
          "item": "Beef tenderloin steaks",
          "quantity": "4 (180–200 g each)",
          "note": "center-cut"
        },
        {
          "item": "Olive oil",
          "quantity": "2 tbsp"
        },
        {
          "item": "Butter",
          "quantity": "2 tbsp"
        },
        {
          "item": "Thyme sprigs",
          "quantity": "2"
        },
        {
          "item": "Garlic cloves",
          "quantity": "2",
          "note": "crushed"
        },
        {
          "item": "Salt",
          "quantity": "",
          "note": "to taste"
        },
        {
          "item": "Black pepper",
          "quantity": "",
          "note": "freshly ground, to taste"
        }
      ],
      "steps": [
        {
          "number": 1,
          "instruction": "Preheat oven to 180°C (350°F)."
        },
        {
          "number": 2,
          "instruction": "Season steaks generously with salt and pepper."
        },
        {
          "number": 3,
          "instruction": "Sear in a cast iron skillet coated in olive oil over high heat until well-browned on all sides."
        },
        {
          "number": 4,
          "instruction": "Add butter, thyme, and garlic; baste for 1–2 minutes."
        },
        {
          "number": 5,
          "instruction": "Transfer to oven and cook until internal temperature reaches 54°C (129°F)."
        },
        {
          "number": 6,
          "instruction": "Rest 5–10 minutes before slicing."
        }
      ]
    },
    {
      "name": "Bone Marrow Sabayon",
      "yield": "",
      "ingredients": [
        {
          "item": "Beef marrow bones",
          "quantity": "2 large",
          "note": "split lengthwise"
        },
        {
          "item": "Egg yolks",
          "quantity": "3"
        },
        {
          "item": "Dry white wine",
          "quantity": "60 mL"
        },
        {
          "item": "Lemon juice",
          "quantity": "1 tsp"
        },
        {
          "item": "Salt",
          "quantity": "",
          "note": "to taste"
        },
        {
          "item": "White pepper",
          "quantity": "",
          "note": "to taste"
        }
      ],
      "steps": [
        {
          "number": 1,
          "instruction": "Roast marrow bones at 200°C (400°F) for 15–20 minutes until soft and releasing fat."
        },
        {
          "number": 2,
          "instruction": "Scoop out marrow and strain through fine mesh to remove impurities."
        },
        {
          "number": 3,
          "instruction": "In a heatproof bowl over simmering water, whisk egg yolks and wine until thick and foamy."
        },
        {
          "number": 4,
          "instruction": "Slowly whisk in warm melted bone marrow fat to create an emulsion."
        },
        {
          "number": 5,
          "instruction": "Season with lemon juice, salt, and white pepper."
        },
        {
          "number": 6,
          "instruction": "Keep warm over a bain-marie until ready to serve."
        }
      ]
    },
    {
      "name": "Red Wine Reduction",
      "yield": "",
      "ingredients": [
        {
          "item": "Dry red wine",
          "quantity": "250 mL"
        },
        {
          "item": "Shallot",
          "quantity": "1",
          "note": "minced"
        },
        {
          "item": "Beef stock",
          "quantity": "200 mL"
        },
        {
          "item": "Butter",
          "quantity": "1 tbsp",
          "note": "cold, for finishing"
        },
        {
          "item": "Thyme sprig",
          "quantity": "1"
        }
      ],
      "steps": [
        {
          "number": 1,
          "instruction": "Sauté shallot in a small pan until translucent."
        },
        {
          "number": 2,
          "instruction": "Add wine and thyme; reduce by two-thirds."
        },
        {
          "number": 3,
          "instruction": "Add beef stock and reduce until thick and glossy."
        },
        {
          "number": 4,
          "instruction": "Strain and whisk in cold butter just before serving."
        }
      ]
    }
  ]
}

      "note": ""
    },
    {
      "quantity": "pinch",
      "item": "salt",
      "note": ""
    }
  ],
  "steps": [
    {
      "instruction": "Combine flour, sugar, salt, and yeast in a stand mixer."
    },
    {
      "instruction": "Add eggs and warm milk; mix until a shaggy dough forms."
    },
    {
      "instruction": "Gradually incorporate butter and knead until smooth and elastic (windowpane stage)."
    },
    {
      "instruction": "Proof dough at 75�78�F until doubled, about 90 minutes."
    },
    {
      "instruction": "Refrigerate dough overnight for flavor development and easier handling."
    },
    {
      "instruction": "Prepare brown butter by heating butter until amber and nutty; cool slightly and mix with brown sugar, cinnamon, nutmeg, vanilla, and salt."
    },
    {
      "instruction": "Roll dough into a rectangle, spread filling evenly, and fold into thirds."
    },
    {
      "instruction": "Chill for 20 minutes, then repeat folding process once more for lamination."
    },
    {
      "instruction": "Roll dough to 1/4 inch thickness and slice into 2-inch spirals."
    },
    {
      "instruction": "Place rolls into a buttered baking dish and proof 45�60 minutes until puffy."
    },
    {
      "instruction": "Bake at 350�F (175�C) for 20�25 minutes until golden brown."
    },
    {
      "instruction": "Whisk mascarpone, powdered sugar, vanilla bean, cream, and salt to form glaze."
    },
    {
      "instruction": "Glaze rolls while warm and finish with optional garnishes."
    }
  ],

{
  "name": "Caramelized Vanilla Bean & Brown Butter Cinnamon Rolls",
  "description": "A Michelin-inspired laminated brioche cinnamon roll with caramelized brown butter filling, Ceylon cinnamon, citrus aromatics, and a mascarpone vanilla bean glaze.",
  "category": "Brunch",
  "keywords": "cinnamon rolls, brioche, laminated dough, brown butter, pastry, fine dining, gourmet",
  "yield": "12 rolls",
  "imageUrl": "https://pub-3ae50d56fa834654954be23601470560.r2.dev/assets/caramelized-vanilla-bean-brown-butter-cinnamon-rolls.png",
  "ingredients": [

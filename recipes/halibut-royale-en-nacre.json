{
  "name": "Halibut Royale en Nacre",
  "imageUrl": "https://pub-3ae50d56fa834654954be23601470560.r2.dev/assets/Photos/Recipes/Halibut.png",
  "yield": "2 plates",
  "description": "A refined Michelin-style halibut dish featuring butter-poached fish, champagne beurre blanc, and delicate spring vegetables with luxurious garnishes.",
  "category": "Main",
  "keywords": "halibut, fine dining, seafood, michelin, beurre blanc",
  "winePairings": [
    {
      "name": "Champagne Brut",
      "notes": "Bright acidity enhances the beurre blanc and balances the richness."
    },
    {
      "name": "Chablis Grand Cru",
      "notes": "Minerality and citrus notes complement the delicate halibut."
    }
  ],
  "ingredients": [
    {
      "item": "Halibut fillets (center-cut, skinless)",
      "quantity": "2 (6 oz each)"
    },
    {
      "item": "Unsalted butter",
      "quantity": "350 g",
      "note": "divided for poaching and sauce"
    },
    {
      "item": "Garlic clove",
      "quantity": "1",
      "note": "crushed"
    },
    {
      "item": "Thyme sprig",
      "quantity": "1"
    },
    {
      "item": "Shallot",
      "quantity": "1",
      "note": "finely minced"
    },
    {
      "item": "Champagne",
      "quantity": "150 ml"
    },
    {
      "item": "White wine vinegar",
      "quantity": "1 tbsp"
    },
    {
      "item": "English peas",
      "quantity": "1/2 cup"
    },
    {
      "item": "Baby leeks or scallions",
      "quantity": "4-6"
    },
    {
      "item": "Microgreens",
      "quantity": "small handful"
    },
    {
      "item": "Lemon zest",
      "quantity": "to finish"
    },
    {
      "item": "Salt and white pepper",
      "quantity": "to taste"
    },
    {
      "item": "Caviar (optional)",
      "quantity": "small spoonful"
    },
    {
      "item": "Edible flowers (optional)",
      "quantity": "for garnish"
    },
    {
      "item": "Gold leaf (optional)",
      "quantity": "for garnish"
    }
  ],
  "specialtools": [
    {
      "item": "Sous Vide Circulator",
      "link": "https://amzn.to/48bdTV7"
    },
    {
      "item": "Cast Iron Skillet",
      "link": "https://amzn.to/3ObTjgD"
    },
    {
      "item": "Whisk",
      "link": "https://amzn.to/3OOE9Ov"
    },
    {
      "item": "Vacuum Sealer",
      "link": "https://amzn.to/4ufPoPh"
    },
    {
      "item": "Fine Chinois",
      "link": "https://amzn.to/3OPQuls"
    },
    {
      "item": "Fish Spatula",
      "link": "https://amzn.to/3OQLQ6N"
    },
    {
      "item": "Squeeze Bottle",
      "link": "https://amzn.to/3QkAbxs"
    }
  ],
  "steps": [
    {
      "number": 1,
      "instruction": "Season the halibut lightly with salt and white pepper and place into a vacuum bag with butter, garlic, and thyme."
    },
    {
      "number": 2,
      "instruction": "Seal and cook in a water bath at 122°F (50°C) for 25 minutes.",
      "note": "ensures a delicate, silky texture"
    },
    {
      "number": 3,
      "instruction": "Prepare the Champagne Beurre Blanc",
      "note": "see sub-recipe"
    },
    {
      "number": 4,
      "instruction": "Blanch peas in salted boiling water, then shock in ice water.",
      "note": "keeps color vibrant"
    },
    {
      "number": 5,
      "instruction": "Lightly sauté baby leeks in butter until tender."
    },
    {
      "number": 6,
      "instruction": "Remove halibut from bag and gently pat dry."
    },
    {
      "number": 7,
      "instruction": "Sear halibut briefly in a hot pan with butter to create a light golden crust.",
      "note": "do not overcook"
    },
    {
      "number": 8,
      "instruction": "Plating: Spoon beurre blanc onto the plate as a base."
    },
    {
      "number": 9,
      "instruction": "Place halibut slightly off-center on the sauce."
    },
    {
      "number": 10,
      "instruction": "Arrange peas and leeks with height and balance."
    },
    {
      "number": 11,
      "instruction": "Garnish with microgreens, lemon zest, and optional caviar or gold leaf."
    }
  ],
  "sub_recipes": [
    {
      "name": "Champagne Beurre Blanc",
      "ingredients": [
        {
          "item": "Shallot",
          "quantity": "1",
          "note": "finely minced"
        },
        {
          "item": "Champagne",
          "quantity": "150 ml"
        },
        {
          "item": "White wine vinegar",
          "quantity": "1 tbsp"
        },
        {
          "item": "Cold butter",
          "quantity": "150 g",
          "note": "cubed"
        },
        {
          "item": "Salt",
          "quantity": "to taste"
        }
      ],
      "steps": [
        {
          "number": 1,
          "instruction": "Combine shallots, champagne, and vinegar in a saucepan and reduce until nearly dry."
        },
        {
          "number": 2,
          "instruction": "Lower heat and whisk in cold butter gradually until emulsified."
        },
        {
          "number": 3,
          "instruction": "Strain through a fine chinois for a smooth finish."
        },
        {
          "number": 4,
          "instruction": "Keep warm but not hot to prevent splitting."
        }
      ]
    }
  ]
}

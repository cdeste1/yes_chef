  "steps": [
    {
      "number": 1,
      "instruction": "Prepare herb oil by blanching parsley and chives for 15 seconds, shocking in ice water, blending with grapeseed oil, and straining overnight."
    },
    {
      "number": 2,
      "instruction": "Make the brioche crumble by tossing torn brioche with brown butter and sea salt, then baking at 325°F until golden."
    },
    {
      "number": 3,
      "instruction": "Dehydrate sliced shallots until crisp and blend half into ash powder. Fold into the crumble."
    },
    {
      "number": 4,
      "instruction": "Prepare the Comté velouté by sweating shallots gently in butter, then adding milk, cream, and bay leaf. Simmer 15 minutes."
    },
    {
      "number": 5,
      "instruction": "Remove bay leaf and blend in grated Comté until smooth. Pass through a tamis or chinois."
    },
    {
      "number": 6,
      "instruction": "Prepare black garlic beurre monté by warming butter to 160°F and blending with black garlic, spinach stock, and sherry vinegar."
    },
    {
      "number": 7,
      "instruction": "Heat the Konro grill with Binchotan charcoal until evenly glowing."
    },
    {
      "number": 8,
      "instruction": "Lightly smoke spinach over the Konro using a perforated grill basket."
    },
    {
      "number": 9,
      "instruction": "Transfer spinach to a sauté pan with cultured butter and wilt rapidly over high heat for 20–30 seconds."
    },
    {
      "number": 10,
      "instruction": "Season spinach with Maldon salt and white pepper, then fold in black garlic beurre monté."
    },
    {
      "number": 11,
      "instruction": "Place spinach under a cloche and infuse with applewood smoke using a smoking gun for 45 seconds."
    },
    {
      "number": 12,
      "instruction": "Plate by spooning Comté velouté onto the plate, twisting spinach into a nest, and finishing with brioche crumble, herb oil, lemon ash, micro sorrel, and brown butter pearls."
    }
  ],

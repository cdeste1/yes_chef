          "item": "Parmigiano Reggiano (24-month aged)",
          "quantity": "50 g",
          "note": "finely grated"
        }
      ],
      "steps": [
        {
          "number": 1,
          "instruction": "Preheat oven to 350°F. (175°C)"
        },
        {
          "number": 2,
          "instruction": "Spread cheese into thin circles on a silicone mat."
        },
        {
          "number": 3,
          "instruction": "Bake 4–5 minutes until golden and crisp."
        },
        {
          "number": 4,
          "instruction": "Cool on a rack before use."
        }
      ]
    },
    {

  "steps": [
    {
      "number": 1,
      "instruction": "Score the inside of the squid tubes in a crosshatch pattern without cutting through completely."
    },
    {
      "number": 2,
      "instruction": "Mix sea salt, sugar, and lemon zest. Lightly cure squid for 20 minutes in the refrigerator."
    },
    {
      "number": 3,
      "instruction": "Rinse squid gently and pat completely dry."
    },
    {
      "number": 4,
      "instruction": "Prepare smoked squid consommé",
      "note": "see sub-recipe"
    },
    {
      "number": 5,
      "instruction": "Prepare preserved lemon gel",
      "note": "see sub-recipe"
    },
    {
      "number": 6,
      "instruction": "Prepare black garlic emulsion",
      "note": "see sub-recipe"
    },
    {
      "number": 7,
      "instruction": "Prepare squid ink rice lace crisp",
      "note": "see sub-recipe"
    },
    {
      "number": 8,
      "instruction": "Brush squid lightly with olive oil and grill over extremely hot binchotan charcoal for 45–60 seconds per side until lightly blistered."
    },
    {
      "number": 9,
      "instruction": "Melt cultured butter with squid ink and glaze the grilled calamari immediately after cooking."
    },
    {
      "number": 10,
      "instruction": "Rest calamari for 1 minute before slicing into elegant ribbons."
    },
    {
      "number": 11,
      "instruction": "Plate smoked consommé reduction in the center of matte black stoneware."
    },
    {
      "number": 12,
      "instruction": "Arrange calamari ribbons and tentacles vertically for height and movement."
    },
    {
      "number": 13,
      "instruction": "Add dots of preserved lemon gel and swipes of black garlic emulsion."
    },
    {
      "number": 14,
      "instruction": "Insert rice lace crisp shards for texture and architecture."
    },
    {
      "number": 15,
      "instruction": "Finish with herb oil, finger lime pearls, bronze fennel, edible flowers, and Maldon salt."
    }
  ],

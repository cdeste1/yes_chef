  "sub_recipes": [
    {
      "name": "Roasted Chicken",
      "yield": "",
      "ingredients": [
        {
          "item": "Whole chicken",
          "quantity": "1 (1.5–1.8 kg)",
          "note": "preferably organic or free-range"
        },
        {
          "item": "Olive oil",
          "quantity": "2 tbsp"
        },
        {
          "item": "Butter",
          "quantity": "2 tbsp",
          "note": "softened"
        },
        {
          "item": "Fresh thyme",
          "quantity": "2 sprigs"
        },
        {
          "item": "Garlic",
          "quantity": "3 cloves",
          "note": "crushed"
        },
        {
          "item": "Salt",
          "quantity": "",
          "note": "to taste"
        },
        {
          "item": "Black pepper",
          "quantity": "",
          "note": "freshly ground, to taste"
        }
      ],
      "steps": [
        {
          "number": 1,
          "instruction": "Preheat oven to 200°C (400°F)."
        },
        {
          "number": 2,
          "instruction": "Pat chicken dry and rub with olive oil, butter, salt, and pepper."
        },
        {
          "number": 3,
          "instruction": "Stuff cavity with thyme and crushed garlic."
        },
        {
          "number": 4,
          "instruction": "Roast for 50–60 minutes, basting occasionally, until golden and internal temperature reaches 74°C (165°F)."
        },
        {
          "number": 5,
          "instruction": "Rest 10–15 minutes before carving."
        }
      ]
    },
    {
      "name": "Wild Mushroom Sauté",
      "yield": "",
      "ingredients": [
        {
          "item": "Mixed wild mushrooms",
          "quantity": "300 g",
          "note": "chanterelles, shiitake, oyster, or morels"
        },
        {
          "item": "Butter",
          "quantity": "1 tbsp"
        },
        {
          "item": "Olive oil",
          "quantity": "1 tbsp"
        },
        {
          "item": "Shallot",
          "quantity": "1 small",
          "note": "minced"
        },
        {
          "item": "Thyme leaves",
          "quantity": "½ tsp"
        },
        {
          "item": "Salt",
          "quantity": "",
          "note": "to taste"
        },
        {
          "item": "Black pepper",
          "quantity": "",
          "note": "to taste"
        }
      ],
      "steps": [
        {
          "number": 1,
          "instruction": "Heat butter and olive oil in a sauté pan over medium heat."
        },
        {
          "number": 2,
          "instruction": "Add shallot and cook until translucent."
        },
        {
          "number": 3,
          "instruction": "Add mushrooms and thyme; sauté until golden and moisture evaporates."
        },
        {
          "number": 4,
          "instruction": "Season with salt and pepper; set aside warm."
        }
      ]
    },
    {
      "name": "Sherry Reduction",
      "yield": "",
      "ingredients": [
        {
          "item": "Dry sherry",
          "quantity": "150 mL"
        },
        {
          "item": "Chicken stock",
          "quantity": "200 mL"
        },
        {
          "item": "Butter",
          "quantity": "1 tbsp",
          "note": "cold, for finishing"
        },
        {
          "item": "Shallot",
          "quantity": "1 small",
          "note": "finely chopped"
        },
        {
          "item": "Thyme sprig",
          "quantity": "1"
        }
      ],
      "steps": [
        {
          "number": 1,
          "instruction": "Sauté shallot in a small saucepan with a touch of butter until soft."
        },
        {
          "number": 2,
          "instruction": "Add sherry and thyme; reduce by half."
        },
        {
          "number": 3,
          "instruction": "Add chicken stock; continue reducing until glossy and thickened."
        },
        {
          "number": 4,
          "instruction": "Strain and whisk in cold butter before serving."
        }
      ]
    }
  ]
}

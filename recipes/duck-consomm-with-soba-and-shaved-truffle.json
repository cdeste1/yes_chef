  "steps": [
    {
      "number": 1,
      "instruction": "Reheat consommé gently without boiling."
    },
    {
      "number": 2,
      "instruction": "Place cooked soba noodles in the center of warmed soup bowls."
    },
    {
      "number": 3,
      "instruction": "Pour consommé around noodles carefully to maintain clarity."
    },
    {
      "number": 4,
      "instruction": "Top with shaved truffles. Optionally, drizzle a few drops of truffle oil for aroma."
    }

    {
      "name": "Sous Vide the Patties (Perfect interior)",
      "yield": "",
      "ingredients": [],
      "steps": [
        {
          "instruction": "Lightly season patties."
        },
        {
          "instruction": "Vacuum seal using Vacuum Sealer Machine"
        },
        {
          "instruction": "Cook in water bath with Sous Vide Precision Cooker: 131°F (55°C) for 45 minutes."
        }
      ]
    },
    {
      "name": "Caramelized Onion Purée (Silky refinement)",
      "yield": "",
      "ingredients": [],
      "steps": [
        {
          "instruction": "Cook onions in butter over low heat for 25–30 minutes."
        },
        {
          "instruction": "Add sugar halfway; finish with balsamic."
        },
        {
          "instruction": "Blend until smooth."
        },
        {
          "instruction": "Strain through fine mesh strainer."
        }
      ]
    },
    {
      "name": "Truffle Aioli",
      "yield": "",
      "ingredients": [],
      "steps": [
        {
          "instruction": "Mix mayonnaise, truffle oil,  Dijon mustard, garlic and lemon juice"
        },
        {
          "instruction": "Strain for smoothness."
        },
        {
          "instruction": "Transfer to squeeze bottle"
        }
      ]
    },
    {
      "name": "Sear + Torch Finish ??",
      "yield": "",
      "ingredients": [],
      "steps": [
        {
          "instruction": "Remove patties from sous vide, pat completely dry."
        },
        {
          "instruction": "Sear in very hot pan (30–45 sec per side)."
        },
        {
          "instruction": "Add cheese during final seconds"
        },
        {
          "instruction": "Use hand torch to melt the cheese evenly and add controlled char"
        }
      ]
    },
    {
      "name": "Optional Luxury Layer",
      "yield": "",
      "ingredients": [],
      "steps": [
        {
          "instruction": "Quickly sear foie gras (30 sec per side)"
        },
        {
          "instruction": "Sauté mushrooms in butter + thyme until golden"
        }
      ]
    },
    {
      "name": "Toast the Brioche Buns",
      "yield": "",
      "ingredients": [],
      "steps": [
        {
          "instruction": "Butter cut sides"
        },
        {
          "instruction": "Toast until golden and crisp"
        }
      ]
    },
    {
      "name": "Structured Assembly (Using Ring Mold)",
      "yield": "",
      "ingredients": [],
      "steps": [
        {
          "instruction": "Place ring mold on plate and build"
        },
        {
          "instruction": "Bottom bun + thin truffle aioli layer."
        },
        {
          "instruction": "Pipe onion purée neatly."
        },
        {
          "instruction": "Add lettuce"
        },
        {
          "instruction": "Place burger patty with melted cheese"
        },
        {
          "instruction": "Add foie gras and/or mushrooms"
        },
        {
          "instruction": "Tomato slice"
        },
        {
          "instruction": "Microgreens"
        },
        {
          "instruction": "Top bun"
        },
        {
          "instruction": "Carefully remove ring mold for a clean, vertical stack"
        }
      ]
    },
    {
      "name": "Michelin-Level Plating",
      "yield": "",
      "ingredients": [],
      "steps": [
        {
          "instruction": "Place burger slightly off-center on a stone or matte plate"
        },
        {
          "instruction": "Pipe aioli dots using squeeze bottle"
        },
        {
          "instruction": "Add balsamic reduction drops around plate"
        },
        {
          "instruction": "Serve fries in a small metal cup"
        },
        {
          "instruction": "Garnish with microgreens, microplaned cheese (using Microplane), and Flaky Salt"
        }

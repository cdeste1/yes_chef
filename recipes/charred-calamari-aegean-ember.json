        },
        {
          "number": 6,
          "instruction": "Cold smoke using a smoking gun under a cloche for 1 minute."
        }
      ]
    },
    {
      "name": "Preserved Lemon Gel",
      "yield": "1 squeeze bottle",
      "ingredients": [
        {
          "quantity": "2 tbsp",
          "item": "preserved lemon flesh",
          "note": ""
        },
        {
          "quantity": "100ml",
          "item": "water",
          "note": ""
        },
        {
          "quantity": "1 tsp",
          "item": "sugar",
          "note": ""
        },
        {
          "quantity": "1g",
          "item": "agar agar",
          "note": ""
        }
      ],
      "steps": [
        {
          "number": 1,
          "instruction": "Blend preserved lemon, water, and sugar until smooth."
        },
        {
          "number": 2,
          "instruction": "Whisk in agar agar and boil for 30 seconds."
        },
        {
          "number": 3,
          "instruction": "Set in a shallow tray until firm."
        },
        {
          "number": 4,
          "instruction": "Blend again until glossy and smooth, then transfer to squeeze bottle."
        }
      ]
    },
    {
      "name": "Black Garlic Emulsion",
      "yield": "1 cup",
      "ingredients": [
        {
          "quantity": "5 cloves",
          "item": "black garlic",
          "note": ""
        },
        {
          "quantity": "1",
          "item": "egg yolk",
          "note": ""
        },
        {
          "quantity": "1 tsp",
          "item": "Dijon mustard",
          "note": ""
        },
        {
          "quantity": "120ml",
          "item": "grapeseed oil",
          "note": ""
        },
        {
          "quantity": "1 tsp",
          "item": "sherry vinegar",
          "note": ""
        }
      ],
      "steps": [
        {
          "number": 1,
          "instruction": "Blend egg yolk, Dijon mustard, and black garlic until smooth."
        },
        {
          "number": 2,
          "instruction": "Slowly stream in grapeseed oil until emulsified."
        },
        {
          "number": 3,
          "instruction": "Finish with sherry vinegar and season lightly."
        },
        {
          "number": 4,
          "instruction": "Pass through a fine sieve for an ultra-smooth finish."
        }
      ]
    },
    {
      "name": "Squid Ink Rice Lace Crisp",
      "yield": "8 crisp shards",
      "ingredients": [
        {
          "quantity": "80g",
          "item": "rice flour",
          "note": ""
        },
        {
          "quantity": "250ml",
          "item": "water",
          "note": ""
        },
        {
          "quantity": "1 tsp",
          "item": "squid ink",
          "note": ""
        },
        {
          "quantity": "1 tsp",
          "item": "toasted nori powder",
          "note": ""
        }
      ],
      "steps": [
        {
          "number": 1,
          "instruction": "Whisk rice flour, water, squid ink, and nori powder together until smooth."
        },
        {
          "number": 2,
          "instruction": "Pour a very thin layer into a lightly oiled nonstick pan over medium-high heat."
        },
        {
          "number": 3,
          "instruction": "Allow mixture to bubble aggressively until a lacy structure forms."
        },
        {
          "number": 4,
          "instruction": "Cook until crisp and carefully transfer to paper towel."
        }
      ]

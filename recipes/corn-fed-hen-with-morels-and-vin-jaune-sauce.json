      ],
      "steps": [
        {
          "number": 1,
          "instruction": "Season the hen generously with salt and pepper."
        },
        {
          "number": 2,
          "instruction": "Heat butter and oil in skillet or roasting pan."
        },
        {
          "number": 3,
